{
  "name": "techdeals-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test tests/e2e",
    "test:e2e:ci": "playwright test tests/e2e --reporter=html,line",
    "test:a11y": "playwright test tests/accessibility --project=chromium",
    "test:visual": "playwright test tests/visual --project=responsive-390 --project=responsive-768 --project=responsive-1440",
    "lhci": "lhci autorun",
    "bundle:analyze": "cross-env ANALYZE=true next build",
    "security:audit": "npm audit --audit-level=high",
    "qa": "run-s lint type-check test:coverage build",
    "seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate",
    "prepare": "husky",
    "analyze": "cross-env ANALYZE=true npm run build"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "tmp": "^0.2.6"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.1",
    "@auth/prisma-adapter": "^2.11.2",
    "@google/generative-ai": "^0.24.1",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10.63.0",
    "@supabase/supabase-js": "^2.110.0",
    "@tanstack/react-query": "^5.101.2",
    "@types/bcryptjs": "^3.0.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/og": "^0.11.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "cloudinary": "^2.10.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "next-auth": "^4.24.14",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.80.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "axe-core": "^4.12.1",
    "cross-env": "^10.1.0",
    "eslint": "^10",
    "eslint-config-next": "^16.2.10",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.4",
    "start-server-and-test": "^3.0.11",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^6",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  }
}
